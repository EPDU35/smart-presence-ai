# Copier ce fichier en ".env" à la racine du projet :
#   copy .env.example .env
# Puis remplir avec vos clés Supabase (Settings → API)

VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_ANON_KEY=votre_cle_anon_publique

VITE_APP_NAME=Smart Presence
VITE_APP_URL=http://localhost:5173

# Durée de validité du QR affiché (secondes)
VITE_QR_EXPIRY_SECONDS=30

VITE_DEFAULT_RADIUS_METERS=100
VITE_OTP_EXPIRY_SECONDS=300
